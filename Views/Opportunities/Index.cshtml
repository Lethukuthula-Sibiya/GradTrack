@model IEnumerable<GradTrack.Models.Opportunity>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <input type="text"
               name="searchString"
               class="form-control"
               placeholder="Search company or opportunity..."
               value="@ViewData["CurrentFilter"]" />
        </div>

    <div class="col-md-3">
        <select name="statusFilter" class="form-select">
            <option value="">All Statuses</option>

            <option value="Applied"
                    selected="@(ViewData["CurrentStatus"]?.ToString() == "Applied")">
                Applied
            </option>

            <option value="Interview"
                    selected="@(ViewData["CurrentStatus"]?.ToString() == "Interview")">
                Interview
            </option>

            <option value="Offer"
                    selected="@(ViewData["CurrentStatus"]?.ToString() == "Offer")">
                Offer
            </option>

            <option value="Rejected"
                    selected="@(ViewData["CurrentStatus"]?.ToString() == "Rejected")">
                Rejected
            </option>

        </select>
    </div>

        <div class="col-md-2">
            <input type="submit"
                   value="Search"
                   class="btn btn-primary" />
        </div>

        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-secondary">
                Clear
            </a>
        </div>
</form>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CompanyName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OpportunityName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OpportunityType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Deadline)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Notes)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.CompanyName)
            </td>
            <td>
                @Html.DisplayFor(model => item.OpportunityName)
            </td>
            <td>
                @Html.DisplayFor(model => item.OpportunityType)
            </td>
            <td>
                @Html.DisplayFor(model => item.Deadline)
            </td>
            <td>
                    @if (item.Status == "Applied")
                    {
                        <span class="badge bg-primary">Applied</span>
                    }
                    else if (item.Status == "Interview")
                    {
                        <span class="badge bg-warning text-dark">Interview</span>
                    }
                    else if (item.Status == "Offer")
                    {
                        <span class="badge bg-success">Offer</span>
                    }
                    else if (item.Status == "Rejected")
                    {
                        <span class="badge bg-danger">Rejected</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.Status</span>
                    }
            </td>
            <td>
                @Html.DisplayFor(model => item.Notes)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
