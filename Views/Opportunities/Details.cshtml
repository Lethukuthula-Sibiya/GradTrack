@model GradTrack.Models.Opportunity

@{
    ViewData["Title"] = "Opportunity Details";
}

<h1>Opportunity Details</h1>

<hr />

<div class="card">

    <div class="card-body">

        <h4>@Model.CompanyName</h4>

        <p class="text-muted">
            @Model.OpportunityName
        </p>

        <table class="table">

            <tr>
                <th>Opportunity Type</th>
                <td>@Model.OpportunityType</td>
            </tr>

            <tr>
                <th>Status</th>

                <td>

                    @if (Model.Status == "Applied")
                    {
                        <span class="badge bg-primary">Applied</span>
                    }
                    else if (Model.Status == "Interview")
                    {
                        <span class="badge bg-warning text-dark">Interview</span>
                    }
                    else if (Model.Status == "Offer")
                    {
                        <span class="badge bg-success">Offer</span>
                    }
                    else if (Model.Status == "Rejected")
                    {
                        <span class="badge bg-danger">Rejected</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.Status</span>
                    }

                </td>

            </tr>

            <tr>
                <th>Deadline</th>
                <td>@Model.Deadline.ToLongDateString()</td>
            </tr>

            <tr>
                <th>Notes</th>
                <td>@Model.Notes</td>
            </tr>

        </table>

    </div>

</div>

<br />

<a asp-action="Edit"
   asp-route-id="@Model.Id"
   class="btn btn-warning">

    Edit

</a>

<a asp-action="Index"
   class="btn btn-secondary">

    Back to Opportunities

</a>